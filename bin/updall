# homebrew
command -v brew >/dev/null && \
  brew update && sleep 1s && \
  brew upgrade && sleep 1s && \
  brew cleanup && sleep 1s && \
  brew doctor

#rvm
command -v rvm >/dev/null && \
  rvm reload
  rvm use default
  rvm get stable
  rvm get head
  rvm cleanup all

# npm
command -v npm >/dev/null && \
  npm config delete prefix &&
  npm update -g

# nvm
command -v nvm >/dev/null && \
  nvm install --lts --latest-npm
  nvm alias default $(nvm stable)
  nvm use --delete-prefix stable --silent

# docker
command -v docker >/dev/null && \
  docker system prune &&
  docker image prune
