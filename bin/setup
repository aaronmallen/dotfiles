#!/bin/zsh

chsh -s /bin/zsh

[ -f $HOME/functions/echo-functions ] && source $HOME/functions/echo-functions

green_echo "==> Installing Oh My Zsh.."
git clone --depth=1 https://github.com/romkatv/powerlevel10k.git ~/powerlevel10k
/bin/zsh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
touch .zshrc
config checkout main .my_zshrc
echo "[ -f $HOME/.my_zshrc ] && source $HOME/.my_zshrc" >> .zshrc
source .zshrc

green_echo "==> Installing Homebrew..."
/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
brew update
if [ -f /opt/homebrew/bin/brew ]; then
  /opt/homebrew/bin/brew tap Homebrew/bundle
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
brew -v

green_echo "==> Installing Brew Packages..."
brew bundle
source .zshrc

green_echo "==> Installing asdf Plugins..."
source `brew --prefix asdf`/asdf.sh
asdf_plugins=(
  bun
  deno
  golang
  java
  lua
  mysql
  nodejs
  postgres
  python
  redis
  ruby
  sqlite
  yarn
)

for plugin in "${asdf_plugins[@]}"
do
  green_echo "==> Installing asdf Plugin: ${plugin}"
  asdf plugin add ${plugin}
done

for plugin in "${asdf_plugins[@]}"
do
  green_echo "==> Installing latest ${plugin}"
  asdf install ${plugin} latest
  asdf global ${plugin} latest
done

green_echo "==> Configuring Vim..."
curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
/usr/local/bin/vim +PlugInstall +qall

green_echo "==> Configuring Git..."
git config --global user.name "Aaron Allen"
git config --global core.excludesfile $HOME/.gitignore_global
git config --global core.editor vim
git config --global commit.gpgsign true
git config --global commit.template $HOME/.git_commit_template
git config --global pager.branch false
git config --global pager.tag false
git config --global init.defaultBranch main
git config --global alias.fucked "!git reset && git checkout . && git clean -df"
git config --global alias.last "log -1 HEAD"
git config --global gpg.program gpg


green_echo "==> Finalizing Setup"
compaudit | xargs chmod g-w
defaults write com.apple.dock ResetLaunchPad -bool true; killall Dock

green_echo "== Setup Complete =="
echo "################################################################################"
echo "Be sure to complete git configuration by running the following commands:"
echo ""
echo "  git config --global user.email <YOUR_EMAIL>"
echo "  git config --global user.signingKey <YOUR GPG KEY>"
echo "  git config --global github.user <YOUR_GITHUB_USERNAME>"
echo ""
echo "Be sure to setup .machine_profile if it is needed"
echo "################################################################################"
